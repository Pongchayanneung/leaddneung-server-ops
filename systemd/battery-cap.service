# /etc/systemd/system/battery-cap.service
[Unit]
Description=Cap battery charge at 80%
After=multi-user.target
[Service]
Type=oneshot
ExecStart=/bin/bash -c 'for f in /sys/class/power_supply/BAT*/charge_control_end_threshold; do [ -w "$f" ] && echo 80 > "$f"; done'
[Install]
WantedBy=multi-user.target
